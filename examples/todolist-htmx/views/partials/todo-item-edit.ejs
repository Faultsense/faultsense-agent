<div
  id="todo-<%= todo.id %>"
  class="todo-item"
  data-status="editing"
>
  <input type="checkbox" class="checkbox" disabled />

  <!-- todos/save-edit: sentinel for the save flow. Fires on a custom
       'todo:save-edit' event dispatched from the input's blur handler
       below. Using an event-trigger sentinel (instead of fs-trigger
       on the Save button) avoids a race: when the user clicks Save,
       the input blurs first, HTMX's blur trigger sends the hx-post,
       and by the time the click event reaches the Save button the
       server may have already responded and swapped the edit partial
       out — so a click trigger can miss. Blur always fires first. -->
  <div style="display:none"
    fs-assert="todos/save-edit"
    fs-trigger="event:todo:save-edit"
    fs-assert-removed=".todo-edit-input"></div>

  <div class="edit-row">
    <!-- todos/cancel-edit: fires on Escape via keydown filter.
         The script below also dispatches the cancel request via
         htmx.ajax when Escape is pressed. -->
    <input
      class="edit-input todo-edit-input"
      type="text"
      name="text"
      value="<%= todo.text %>"
      autofocus
      hx-post="/todos/<%= todo.id %>"
      hx-trigger="blur, keyup[key=='Enter']"
      hx-target="closest .todo-item"
      hx-swap="outerHTML"
      fs-assert="todos/cancel-edit"
      fs-trigger="keydown:Escape"
      fs-assert-removed=".todo-edit-input"
    />
    <button
      class="save-btn"
      type="button"
      hx-post="/todos/<%= todo.id %>"
      hx-include="closest .todo-item"
      hx-target="closest .todo-item"
      hx-swap="outerHTML"
    >Save</button>
  </div>
</div>
<script>
  ;(function () {
    var el = document.getElementById('todo-<%= todo.id %>')
    if (!el) return
    var input = el.querySelector('.todo-edit-input')
    if (!input) return

    // Explicitly focus the input — `autofocus` only works on initial page
    // parse, not on elements inserted via outerHTML swap. HTMX executes
    // inline scripts synchronously during swap processing, which runs
    // BEFORE the MutationObserver callback microtask fires — so by the
    // time elementResolver checks `focused=true` for todos/edit-item,
    // document.activeElement === input is already true.
    input.focus()
    if (typeof input.select === 'function') input.select()

    // Dispatch a 'todo:save-edit' custom event on blur so the sentinel
    // above can create its save-edit assertion. Escape also causes a
    // blur via our cancel handler, so we skip if the cancel flag was set.
    var cancelled = false
    input.addEventListener('blur', function () {
      if (cancelled) return
      document.dispatchEvent(new CustomEvent('todo:save-edit'))
    })

    // Escape cancels edit by re-fetching the read-only partial.
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        e.preventDefault()
        cancelled = true
        window.htmx.ajax('GET', '/todos/<%= todo.id %>/cancel-edit', {
          target: '#todo-<%= todo.id %>',
          swap: 'outerHTML',
        })
      }
    })
  })()
</script>
