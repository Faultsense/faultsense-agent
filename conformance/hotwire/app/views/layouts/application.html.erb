<!DOCTYPE html>
<html>
  <head>
    <title>Faultsense Hotwire harness</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>

    <!--
      Load order matters: the conformance collector must register on
      window.Faultsense.collectors.conformance before the agent resolves
      data-collector-url. Both Faultsense scripts run synchronously
      before Turbo so the agent is ready to observe Turbo Stream
      mutations from the very first response.
    -->
    <script src="/collector.js"></script>
    <script
      id="fs-agent"
      src="/faultsense-agent.min.js"
      data-release-label="hotwire-harness"
      data-api-key="test"
      data-collector-url="conformance"
      data-gc-interval="5000"></script>

    <!-- Turbo 8 from CDN — we run --skip-asset-pipeline so there's no
         importmap or sprockets to push it through. turbo-rails still
         provides the server-side helpers (turbo_stream.* etc.). -->
    <script
      type="module"
      src="https://cdn.jsdelivr.net/npm/@hotwired/turbo@8.0.13/dist/turbo.es2017-esm.js"
    ></script>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
