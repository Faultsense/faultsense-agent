<%# Scenario 6: todos/count-updated — OOB from every CRUD action.
    Re-rendered by the server on every response and swapped in via
    hx-swap-oob in the combined response templates. %>
<div id="todo-count"
  fs-assert="todos/count-updated"
  fs-assert-oob="todos/add-item,todos/remove-item,todos/toggle-complete"
  fs-assert-visible="#todo-count[text-matches=\d+ / \d+ remaining]">
  <%= todos.filter(function(t) { return !t.completed }).length %> / <%= todos.length %> remaining
</div>
