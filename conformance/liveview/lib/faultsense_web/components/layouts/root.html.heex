<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()} />
    <.live_title>Faultsense LiveView harness</.live_title>

    <%!--
      Load order: the conformance collector must register on
      window.Faultsense.collectors.conformance BEFORE the agent
      resolves data-collector-url. Both run synchronously before
      Phoenix/LiveView JS so the agent observes the SSR DOM before
      LiveView's morph patches start flowing.
    --%>
    <script src="/collector.js"></script>
    <script
      id="fs-agent"
      src="/faultsense-agent.min.js"
      data-release-label="liveview-harness"
      data-api-key="test"
      data-collector-url="conformance"
      data-gc-interval="5000"
    >
    </script>

    <%!--
      Phoenix + LiveView client runtimes, copied from deps/ at image
      build time. The inline module script wires up the LiveSocket and
      kicks off the JS-side morphdom patching pipeline that makes
      toggle/add/remove interactive.
    --%>
    <script src="/phoenix.js"></script>
    <script src="/phoenix_live_view.js"></script>
    <script type="module">
      const csrfToken = document
        .querySelector("meta[name='csrf-token']")
        .getAttribute("content");

      const liveSocket = new window.LiveView.LiveSocket("/live", window.Phoenix.Socket, {
        longPollFallbackMs: 2500,
        params: { _csrf_token: csrfToken },
      });
      liveSocket.connect();
      window.liveSocket = liveSocket;
    </script>
  </head>
  <body>
    <%= @inner_content %>
  </body>
</html>
